<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/catalogo.css">
    <title>NovaDrive | Registro</title>
</head>
<body>
<div id="Login-Page">
    <div id="Login-Left">
        <img src="img\NovaDriveLogo_BLANCO.png" alt="NovaDrive">
    </div>
    <div id="Login-Right">
        <h1>Bienvenido</h1>
        <h2>Regístrate</h2>

        {{#if error}}
            <p class="login-error">{{error}}</p>
        {{/if}}

        <p style="font-size:13px; color:#555; margin-bottom:16px;">
            ¿Ya tienes cuenta? <a href="/login" style="color:#111; font-weight:bold;">Inicia sesión</a>
        </p>

        <form action="/registro" method="POST" style="width:100%; max-width:340px; display:flex; flex-direction:column; gap:12px;">
            <div class="form-group">
                <input type="email" name="correo" placeholder="Correo electrónico:" required>
            </div>
            <div class="form-group">
                <input type="password" name="contrasena" placeholder="Contraseña:" required>
            </div>
            <button type="submit" class="btn-login">Registrarse</button>
        </form>
    </div>
</div>
</body>
</html>